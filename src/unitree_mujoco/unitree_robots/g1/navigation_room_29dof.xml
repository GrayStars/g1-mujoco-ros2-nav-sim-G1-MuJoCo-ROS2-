<mujoco model="g1_29dof_navigation_room">
  <!-- 指定机器人模型 -->
  <include file="g1_29dof.xml"/>

  <statistic center="0 0 0.7" extent="4.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="nav_groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="nav_groundplane" texture="nav_groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="nav_wall" rgba="0.7 0.7 0.7 1"/>
    <material name="nav_box" rgba="1.0 0.5 0.0 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="nav_groundplane"/>

    <geom name="wall_north" type="box" size="2.0 0.05 1.0" pos="0 2.0 1.0" material="nav_wall"/>
    <geom name="wall_south" type="box" size="2.0 0.05 1.0" pos="0 -2.0 1.0" material="nav_wall"/>
    <geom name="wall_east" type="box" size="0.05 2.0 1.0" pos="2.0 0 1.0" material="nav_wall"/>
    <geom name="wall_west" type="box" size="0.05 2.0 1.0" pos="-2.0 0 1.0" material="nav_wall"/>

    <body name="target_box" pos="-1.5 1.0 0.15">
      <geom name="box" type="box" size="0.15 0.15 0.15" material="nav_box"/>
    </body>
  </worldbody>
</mujoco>
